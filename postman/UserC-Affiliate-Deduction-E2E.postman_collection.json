{
  "info": {
    "name": "User C Deposit E2E - Affiliate Deduction Verify",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "End-to-end proof: User C uses parent gateway (SubAdmin), but bonus deduction comes from Affiliate."
  },
  "item": [
    {
      "name": "1) Create SubAdmin (Parent)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"subadmin_{{$timestamp}}@mail.com\",\n  \"password\": \"Pass1234\",\n  \"firstName\": \"Sub\",\n  \"lastName\": \"Admin\",\n  \"mobile\": \"01711{{$randomInt}}\",\n  \"countryCode\": \"+880\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/auth/register_Sub_admin",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "auth", "register_Sub_admin"]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const ts = Date.now().toString().slice(-6);",
              "pm.environment.set('ts', ts);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 2xx', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "const r = pm.response.json();",
              "const user = (r.data && r.data.user) ? r.data.user : null;",
              "pm.test('SubAdmin user present', function () {",
              "  pm.expect(user).to.exist;",
              "  pm.expect(user.userId).to.be.a('string');",
              "  pm.expect(user.referralCode).to.be.a('string');",
              "});",
              "pm.environment.set('subAdminUserId', user.userId);",
              "pm.environment.set('subAdminReferralCode', user.referralCode);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2) Create Affiliate (under SubAdmin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"aff{{ts}}\",\n  \"email\": \"aff_{{ts}}@mail.com\",\n  \"password\": \"Pass1234\",\n  \"firstName\": \"Aff\",\n  \"lastName\": \"One\",\n  \"referredBy\": \"{{subAdminReferralCode}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/auth/register_affiliate",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "auth", "register_affiliate"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.expect(pm.response.code).to.equal(201);",
              "});",
              "const r = pm.response.json();",
              "const user = r.data && r.data.user ? r.data.user : null;",
              "const referralCode = user && user.referralCode ? user.referralCode : (r.data ? r.data.referralCode : null);",
              "pm.test('Affiliate created + referralCode exists', function () {",
              "  pm.expect(user).to.exist;",
              "  pm.expect(user.userId).to.be.a('string');",
              "  pm.expect(referralCode).to.be.a('string');",
              "});",
              "pm.environment.set('affiliateUserId', user.userId);",
              "pm.environment.set('affiliateReferralCode', referralCode);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3) Create User C",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"userc{{ts}}\",\n  \"phone\": \"01733{{$randomInt}}\",\n  \"password\": \"Pass1234\",\n  \"countryCode\": \"+880\",\n  \"name\": \"User C\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/auth/createUser",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "auth", "createUser"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.expect(pm.response.code).to.equal(201);",
              "});",
              "const r = pm.response.json();",
              "const user = r.user || null;",
              "pm.test('User C created', function () {",
              "  pm.expect(user).to.exist;",
              "  pm.expect(user.userId).to.be.a('string');",
              "});",
              "pm.environment.set('userCUserId', user.userId);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4) Attach User C to Affiliate code",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userCUserId}}\",\n  \"referralCode\": \"{{affiliateReferralCode}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/advanced/referral/register-with-code",
          "host": ["{{baseUrl}}"],
          "path": ["api", "advanced", "referral", "register-with-code"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const r = pm.response.json();",
              "pm.test('Referrer is affiliate', function () {",
              "  pm.expect(r.data.referrer.role).to.equal('affiliate');",
              "  pm.expect(r.data.referrer.userId).to.equal(pm.environment.get('affiliateUserId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5) Create Parent Gateway (SubAdmin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ownerId\": \"{{subAdminUserId}}\",\n  \"gatewayName\": \"Parent BKash\",\n  \"gatewayType\": \"bKash\",\n  \"accountNumber\": \"01700001111\",\n  \"accountName\": \"Sub Admin Wallet\",\n  \"minDeposit\": 100,\n  \"maxDeposit\": 500000\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/advanced/gateway/create",
          "host": ["{{baseUrl}}"],
          "path": ["api", "advanced", "gateway", "create"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.expect(pm.response.code).to.equal(201);",
              "});",
              "const r = pm.response.json();",
              "pm.environment.set('gatewayId', r.data.gatewayId);",
              "pm.test('Gateway id saved', function () {",
              "  pm.expect(pm.environment.get('gatewayId')).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6) Verify User C available gateway owner = SubAdmin",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/advanced/deposit-bonus/available-gateways?userId={{userCUserId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "advanced", "deposit-bonus", "available-gateways"],
          "query": [
            { "key": "userId", "value": "{{userCUserId}}" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const r = pm.response.json();",
              "pm.test('At least one gateway exists', function () {",
              "  pm.expect(r.data.gateways.length).to.be.greaterThan(0);",
              "});",
              "pm.test('Gateway owner is parent SubAdmin', function () {",
              "  pm.expect(r.data.gateways[0].ownerId).to.equal(pm.environment.get('subAdminUserId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "7) Verify referral-chain owners before deposit",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/advanced/deposit-bonus/referral-chain?userId={{userCUserId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "advanced", "deposit-bonus", "referral-chain"],
          "query": [
            { "key": "userId", "value": "{{userCUserId}}" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const r = pm.response.json();",
              "pm.test('Gateway owner = SubAdmin', function () {",
              "  pm.expect(r.data.gatewayOwner.userId).to.equal(pm.environment.get('subAdminUserId'));",
              "});",
              "pm.test('Bonus deduction owner = Affiliate', function () {",
              "  pm.expect(r.data.bonusDeductionOwner.userId).to.equal(pm.environment.get('affiliateUserId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "8) User C deposit (main proof)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userCUserId}}\",\n  \"amount\": 1000,\n  \"gatewayId\": \"{{gatewayId}}\",\n  \"paymentMethod\": \"bKash\",\n  \"transactionReference\": \"PM-{{ts}}\",\n  \"accountNumber\": \"01755556666\",\n  \"mobile\": \"01755556666\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/advanced/deposit-bonus/create",
          "host": ["{{baseUrl}}"],
          "path": ["api", "advanced", "deposit-bonus", "create"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const r = pm.response.json();",
              "pm.test('Business logic proof regardless of approve/deny', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 400, 500]);",
              "});",
              "if (pm.response.code === 200 && r && r.data) {",
              "  pm.test('Deduction owner is affiliate (success path)', function () {",
              "    pm.expect(r.data.bonusDeductedFrom).to.equal(pm.environment.get('affiliateUserId'));",
              "  });",
              "  pm.environment.set('mainTransactionId', r.data.transactionId);",
              "} else {",
              "  pm.test('If failed for balance, error indicates affiliate deduction path', function () {",
              "    const msg = (r && (r.message || r.error)) ? (r.message || r.error) : '';",
              "    pm.expect(msg.toLowerCase()).to.include('affiliate');",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "9) Bonus transactions audit",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/advanced/deposit-bonus/bonus-transactions?userId={{userCUserId}}&limit=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "advanced", "deposit-bonus", "bonus-transactions"],
          "query": [
            { "key": "userId", "value": "{{userCUserId}}" },
            { "key": "limit", "value": "20" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const r = pm.response.json();",
              "const txs = (r.data && r.data.transactions) ? r.data.transactions : [];",
              "const depTx = txs.find(t => t.transactionType === 'deposit_bonus');",
              "pm.test('Has deposit_bonus transaction (if deposit succeeded)', function () {",
              "  if (pm.environment.get('mainTransactionId')) {",
              "    pm.expect(depTx).to.exist;",
              "  }",
              "});",
              "if (depTx) {",
              "  pm.test('bonusDeductedFrom = affiliate', function () {",
              "    pm.expect(depTx.bonusDeductedFrom).to.equal(pm.environment.get('affiliateUserId'));",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "ts", "value": "" },
    { "key": "subAdminUserId", "value": "" },
    { "key": "subAdminReferralCode", "value": "" },
    { "key": "affiliateUserId", "value": "" },
    { "key": "affiliateReferralCode", "value": "" },
    { "key": "userCUserId", "value": "" },
    { "key": "gatewayId", "value": "" },
    { "key": "mainTransactionId", "value": "" }
  ]
}
