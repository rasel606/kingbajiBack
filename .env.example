# Backend .env for Contabo VPS Production
# Copy to .env and fill values before deploy

NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# MongoDB (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/megabaji_prod  # or your Atlas URI

# Redis (optional, in-memory fallback)
REDIS_URL=redis://127.0.0.1:6379

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this

# Other secrets (from existing .env)
# Add all required from your current .env

# Logging
LOG_LEVEL=info
