# Backend .env for Contabo VPS Production
# Copy to .env and fill values before deploy

NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# MongoDB (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/megabaji_prod  # or your Atlas URI

# Redis (optional, in-memory fallback)
REDIS_URL=redis://127.0.0.1:6379

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this

# Other secrets (from existing .env)
# Add all required from your current .env

# Logging
LOG_LEVEL=info

# Provider settlement callback security
PROVIDER_SETTLEMENT_VERIFY_SIGNATURE=true
PROVIDER_SETTLEMENT_SECRET=replace_with_long_random_secret
PROVIDER_SETTLEMENT_MAX_SKEW_SECONDS=300
PROVIDER_SETTLEMENT_NONCE_TTL_SECONDS=600
